# Copy this file to /etc/default/ongor-fastapi
# Edit values for your board environment

ONGOR_HOST=0.0.0.0
ONGOR_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://192.168.1.20:3000

# Pose tuning
# Set to 1 if left/right poses are swapped because the camera image is mirrored.
ONGOR_POSE_FLIP=0
# Lower to 0.75 if Test AI shows the right label but /predict.confirmed stays null.
ONGOR_POSE_CONF=0.85
ONGOR_POSE_HOLD=0.6
ONGOR_POSE_PRESENCE=0.6
ONGOR_POSE_ROI_MARGIN=0.85
ONGOR_POSE_SEARCH=1
